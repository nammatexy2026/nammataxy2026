# ============================================================
# NAMMA TAXI BACKEND — ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ----- Server -----
NODE_ENV=development
PORT=5000

# ----- Database (MongoDB) -----
MONGODB_URI=mongodb://127.0.0.1:27017/namma_taxi

# ----- JWT Auth -----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_DO_NOT_USE_IN_PRODUCTION
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# ----- CORS -----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ----- Rate Limiting -----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ----- Logging -----
LOG_LEVEL=debug
LOG_DIR=logs

# ----- Frontend URL (for redirects, emails, etc.) -----
FRONTEND_URL=http://localhost:5173

# ----- Integrations -----
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
